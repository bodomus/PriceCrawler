@model VarPrice.Web.ViewModels.Runs.RunsDashboardVm

@{
    ViewData["Title"] = Model.PageTitle;
}

<div id="runsDashboard"
     class="page-canvas"
     data-runs-tree-url="@Url.Action("RunsTree", "Runs")"
     data-runs-url="@Url.Action("RunsGrid", "Runs")"
     data-snapshots-url="@Url.Action("SnapshotsGrid", "Runs")"
     data-product-details-url="@Url.Action("ProductDetails", "Runs")"
     data-product-analysis-url="@Url.Action("ProductAnalysis", "Runs")"
     data-product-analytics-url="@Url.Action("ProductAnalytics", "Runs")"
     data-live-product-url="@Url.Action("RefreshLiveProduct", "Runs")"
     data-product-history-url="@Url.Action("ProductHistory", "Runs")">
    <div class="page-shell">
        <div class="app-version">Version: @Model.AppVersion</div>

        <header class="top-zone">
            <div id="topToolbar" class="top-toolbar-host"></div>
        </header>

        <div id="dashboardSplitter" class="dashboard-layout">
            <section class="tree-zone" aria-labelledby="crawler-runs-title">
                <div class="dashboard-card dashboard-card-stretch" aria-labelledby="crawler-runs-title">
                    <div class="dashboard-card-header dashboard-card-header-with-actions">
                        <div class="card-headline">
                            <h2 id="crawler-runs-title" class="dashboard-card-title">Crawler Runs</h2>
                            <span id="selectedRunLabel" class="context-label">Selected node: none</span>
                        </div>
                        <button id="refreshRunsTreeButton"
                                class="tree-refresh-button"
                                type="button"
                                title="Refresh tree list"
                                aria-label="Refresh tree list">
                            <span class="tree-refresh-button-icon" aria-hidden="true">
                                <svg viewBox="0 0 24 24">
                                    <path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"></path>
                                    <path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"></path>
                                </svg>
                            </span>
                            <span class="tree-refresh-button-text">Refresh</span>
                        </button>
                    </div>
                    <div class="dashboard-card-body dashboard-tree-body">
                        <div id="runsTreeList" class="dashboard-tree"></div>
                    </div>
                </div>
            </section>

            <section class="dashboard-zone" aria-label="Data workspace">
                <div id="workspaceTabs" class="workspace-tabs-host"></div>

                <main class="dashboard-cards">
                    <section class="dashboard-card dashboard-action-card" aria-labelledby="dashboard-actions-title">
                        <div class="dashboard-card-header">
                            <div class="card-headline">
                                <h2 id="dashboard-actions-title" class="dashboard-card-title">Crawler Control</h2>
                                <span
                                    class="context-label">Launch a crawl and review the latest data in one workspace.</span>
                            </div>
                        </div>
                        <div class="dashboard-card-body dashboard-action-body">
                            <div class="action-intro">
                                <h1 class="action-title">VARUS price cockpit</h1>
                                <p class="action-copy">
                                    Use the existing run and snapshot navigation, then inspect the selected product in
                                    the analytical panel below. Stage 1 reads only from Postgres and does not trigger
                                    live VARUS requests.
                                </p>
                                <div class="action-links">
                                    <a href="/health">Health check</a>
                                </div>
                            </div>

                            <div class="action-panel">
                                <form id="ingestForm" asp-action="IngestVegetables" asp-controller="Runs" method="post">
                                    @Html.AntiForgeryToken()
                                </form>
                                <button id="ingestVegetablesButton" type="button">Collect price snapshot (vegetables)
                                </button>
                            </div>

                            @if (Model.LatestRun is not null)
                            {
                                <div class="summary-strip" aria-label="Latest crawler run">
                                    <div class="summary-chip">
                                        <span class="summary-label">Run</span>
                                        <strong>#@Model.LatestRun.RunId</strong>
                                    </div>
                                    <div class="summary-chip">
                                        <span class="summary-label">Status</span>
                                        <strong>@Model.LatestRun.Status</strong>
                                    </div>
                                    <div class="summary-chip">
                                        <span class="summary-label">Products</span>
                                        <strong>@Model.LatestRun.ProductsProcessed</strong>
                                    </div>
                                    <div class="summary-chip">
                                        <span class="summary-label">Errors</span>
                                        <strong>@Model.LatestRun.Errors</strong>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(Model.LatestRun.Note))
                                    {
                                        <div class="summary-chip summary-chip-wide">
                                            <span class="summary-label">Note</span>
                                            <strong>@Model.LatestRun.Note</strong>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </section>

                    <section class="dashboard-card" aria-labelledby="snapshots-title">
                        <div class="dashboard-card-header">
                            <div class="card-headline">
                                <h2 id="snapshots-title" class="dashboard-card-title">Snapshots</h2>
                                <span id="selectedSnapshotLabel" class="context-label">Selected snapshot: none</span>
                            </div>
                        </div>
                        <div class="dashboard-card-body">
                            <div id="snapshotsGrid" class="dashboard-grid"></div>
                        </div>
                    </section>

                    <div class="analytics-stage">
                        <section class="dashboard-card analytics-card" aria-labelledby="product-card-title">
                            <div class="dashboard-card-header">
                                <div class="card-headline">
                                    <h2 id="product-card-title" class="dashboard-card-title">Product Card</h2>
                                    <span id="productCardContextLabel"
                                          class="context-label">Select a snapshot to inspect a product</span>
                                </div>
                            </div>
                            <div class="dashboard-card-body product-card-body">
                                <div id="productDetailsPanel" class="product-details-panel"></div>
                            </div>
                        </section>

                        <section class="dashboard-card analytics-card" aria-labelledby="price-chart-title">
                            <div class="dashboard-card-header">
                                <div class="card-headline">
                                    <h2 id="price-chart-title" class="dashboard-card-title">Price Chart</h2>
                                    <span id="priceChartContextLabel"
                                          class="context-label">Chart placeholder for the selected product</span>
                                </div>
                            </div>
                            <div class="dashboard-card-body analytics-chart-body">
                                <div id="priceChartPanel" class="price-chart-panel"></div>
                            </div>
                        </section>

                        <section class="dashboard-card analytics-card analytics-history-card"
                                 aria-labelledby="price-history-title">
                            <div class="dashboard-card-header">
                                <div class="card-headline">
                                    <h2 id="price-history-title" class="dashboard-card-title">Price History</h2>
                                    <span id="historyContextLabel"
                                          class="context-label">Select a snapshot to load price history</span>
                                </div>
                            </div>
                            <div class="dashboard-card-body">
                                <div id="analyticsStatus"
                                     class="analytics-status analytics-status-hidden"
                                     role="status"
                                     aria-live="polite"></div>
                                <div id="productHistoryGrid" class="dashboard-grid"></div>
                            </div>
                        </section>
                    </div>
                </main>
            </section>
        </div>
    </div>
</div>

<partial name="_StatusBar" model="Model.StatusBar"/>

@section Scripts {
    <script src="~/js/runs-dashboard.js" asp-append-version="true"></script>
}
