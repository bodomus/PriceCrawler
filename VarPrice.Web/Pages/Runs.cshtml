@page
@model VarPrice.Web.Pages.RunsModel

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>VARUS - Crawler Runs</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.bootstrap5.css" />
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="container-fluid px-3 px-lg-4">
    <h2 class="mb-3">Runs</h2>

    @Html.AntiForgeryToken()

    <div class="row g-3 mb-3">
        <div class="col-12 col-xl-5">
            <div class="card h-100 grid-card">
                <div class="card-header d-flex flex-column justify-content-center">
                    <strong>Crawler Runs</strong>
                    <span id="selectedRunLabel" class="context-label">Selected Run: none</span>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="runsTable" class="table table-striped table-hover table-sm w-100">
                            <thead>
                            <tr>
                                <th>Id</th>
                                <th>StartedAtUtc</th>
                                <th>Status</th>
                                <th>FinishedAtUtc</th>
                                <th>ItemsCount</th>
                            </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card h-100 grid-card">
                <div class="card-header d-flex flex-column justify-content-center">
                    <strong>Snapshots</strong>
                    <span id="selectedSnapshotLabel" class="context-label">Selected Snapshot: none</span>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="snapshotsTable" class="table table-striped table-hover table-sm w-100">
                            <thead>
                            <tr>
                                <th>Id</th>
                                <th>CreatedAtUtc</th>
                                <th>City</th>
                                <th>Price</th>
                                <th>OldPrice</th>
                                <th>Скидка</th>
                                <th>Promo</th>
                                <th>InStock</th>
                            </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card grid-card">
                <div class="card-header d-flex flex-column justify-content-center">
                    <strong>Products</strong>
                    <span id="productContextLabel" class="context-label">Select a snapshot to view products</span>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="productsTable" class="table table-striped table-hover table-sm w-100">
                            <thead>
                            <tr>
                                <th>Id</th>
                                <th>Name</th>
                                <th>Sku</th>
                                <th>URL</th>
                                <th>Price</th>
                                <th>Unit</th>
                                <th>UpdatedAtUtc</th>
                            </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/2.2.2/js/dataTables.js"></script>
<script src="https://cdn.datatables.net/2.2.2/js/dataTables.bootstrap5.js"></script>
<script>
    (() => {
        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? "";
        const selectedRunLabel = document.getElementById('selectedRunLabel');
        const selectedSnapshotLabel = document.getElementById('selectedSnapshotLabel');
        const productContextLabel = document.getElementById('productContextLabel');

        const snapshotEmptyNoRun = 'Select a run to view snapshots';
        const snapshotEmptyNoData = 'No snapshots found for selected run';
        const productEmptyNoSnapshot = 'Select a snapshot to view products';
        const productEmptyNoData = 'No products found for selected snapshot';

        let selectedRunId = null;
        let selectedSnapshotId = null;

        const formatDate = (value) => value ? new Date(value).toLocaleString() : '';
        const formatPrice = (value) => (value === null || value === undefined) ? '' : Number(value).toFixed(2);
        const formatPackUnit = (value) => value ?? '';
        const formatBoolean = (value) => value === null || value === undefined ? '' : (value ? 'Yes' : 'No');
        const formatDiscount = (value) => (value === null || value === undefined) ? '' : `${Number(value).toFixed(1)}%`;

        const setEmptyTableMessage = (table, message) => {
            table.settings()[0].oLanguage.sEmptyTable = message;
        };

        const updateContextLabels = () => {
            selectedRunLabel.textContent = selectedRunId === null ? 'Selected Run: none' : `Selected Run: #${selectedRunId}`;
            selectedSnapshotLabel.textContent = selectedSnapshotId === null
                ? 'Selected Snapshot: none'
                : `Selected Snapshot: #${selectedSnapshotId}`;
            productContextLabel.textContent = selectedSnapshotId === null
                ? productEmptyNoSnapshot
                : `Selected Snapshot: #${selectedSnapshotId}`;
        };

        const applySelection = (table, selectedId) => {
            table.rows().every(function () {
                const rowData = this.data();
                const isSelected = selectedId !== null && rowData && rowData.id === selectedId;
                $(this.node()).toggleClass('table-active', isSelected);
            });
        };

        const runsTable = $('#runsTable').DataTable({
            processing: true,
            serverSide: true,
            searching: true,
            ordering: true,
            paging: true,
            pageLength: 25,
            order: [[1, 'desc']],
            autoWidth: false,
            ajax: {
                url: '@Url.Page("Runs", "RunsData")',
                type: 'POST',
                headers: {
                    RequestVerificationToken: antiForgeryToken
                }
            },
            columns: [
                { data: 'id' },
                {
                    data: 'startedAtUtc',
                    render: (value) => formatDate(value)
                },
                { data: 'status' },
                {
                    data: 'finishedAtUtc',
                    render: (value) => formatDate(value)
                },
                { data: 'itemsCount' }
            ],
            drawCallback: function () {
                applySelection(this.api(), selectedRunId);
            }
        });

        const snapshotsTable = $('#snapshotsTable').DataTable({
            processing: true,
            serverSide: true,
            searching: true,
            ordering: true,
            paging: true,
            pageLength: 25,
            order: [[1, 'desc']],
            autoWidth: false,
            language: {
                emptyTable: snapshotEmptyNoRun
            },
            ajax: {
                url: '@Url.Page("Runs", "SnapshotsData")',
                type: 'POST',
                headers: {
                    RequestVerificationToken: antiForgeryToken
                },
                data: function (d) {
                    d.runId = selectedRunId;
                }
            },
            columns: [
                { data: 'id' },
                {
                    data: 'createdAtUtc',
                    render: (value) => formatDate(value)
                },
                { data: 'city' },
                {
                    data: 'price',
                    render: (value) => formatPrice(value)
                },
                {
                    data: 'oldPrice',
                    render: (value) => formatPrice(value)
                },
                {
                    data: 'discountPercent',
                    render: (value) => formatDiscount(value)
                },
                {
                    data: 'promoFlag',
                    render: (value) => formatBoolean(value)
                },
                {
                    data: 'inStock',
                    render: (value) => formatBoolean(value)
                }
            ],
            rowCallback: function (row, data) {
                const isPromo = data?.promoFlag === true;
                const promoDiscount = data?.discountPercent;
                const isStrongDiscount = isPromo && promoDiscount !== null && promoDiscount > 25;

                row.classList.toggle('snapshot-promo', isPromo);
                row.classList.toggle('snapshot-promo-strong', isStrongDiscount);
            },
            drawCallback: function () {
                applySelection(this.api(), selectedSnapshotId);
            }
        });

        const productsTable = $('#productsTable').DataTable({
            processing: true,
            serverSide: true,
            searching: true,
            ordering: true,
            paging: true,
            pageLength: 50,
            order: [[1, 'asc']],
            autoWidth: false,
            language: {
                emptyTable: productEmptyNoSnapshot
            },
            ajax: {
                url: '@Url.Page("Runs", "ProductsData")',
                type: 'POST',
                headers: {
                    RequestVerificationToken: antiForgeryToken
                },
                data: function (d) {
                    d.snapshotId = selectedSnapshotId;
                }
            },
            columns: [
                { data: 'id' },
                { data: 'name' },
                { data: 'sku' },
                {
                    data: 'url',
                    render: (value) => value
                        ? `<a href="${value}" target="_blank" rel="noopener noreferrer">${value}</a>`
                        : ''
                },
                {
                    data: 'price',
                    render: (value) => formatPrice(value)
                },
                {
                    data: 'unit',
                    render: (value) => formatPackUnit(value)
                },
                {
                    data: 'updatedAtUtc',
                    render: (value) => formatDate(value)
                }
            ]
        });

        $('#runsTable tbody').on('click', 'tr', function () {
            const rowData = runsTable.row(this).data();
            if (!rowData) {
                return;
            }

            selectedRunId = rowData.id;
            selectedSnapshotId = null;
            updateContextLabels();

            setEmptyTableMessage(snapshotsTable, snapshotEmptyNoData);
            setEmptyTableMessage(productsTable, productEmptyNoSnapshot);

            snapshotsTable.ajax.reload();
            productsTable.ajax.reload();
            applySelection(runsTable, selectedRunId);
        });

        $('#snapshotsTable tbody').on('click', 'tr', function () {
            const rowData = snapshotsTable.row(this).data();
            if (!rowData) {
                return;
            }

            selectedSnapshotId = rowData.id;
            updateContextLabels();

            setEmptyTableMessage(productsTable, productEmptyNoData);
            productsTable.ajax.reload();
            applySelection(snapshotsTable, selectedSnapshotId);
        });

        updateContextLabels();
    })();
</script>
</body>
</html>
